{
  "name": "event-tracker",
  "version": "1.0.0",
  "description": "Event tracking system for managing attendees and sharing data with teams",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "postbuild": "npm run build",
    "test": "node test.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "dotenv": "^17.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  },
  "keywords": ["event", "tracking", "attendees", "management"],
  "author": "Event Tracker Team",
  "license": "MIT"
}
